{
  "name": "slovenskeludovkymobile",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "main": "expo-router/entry",
  "scripts": {
    "preinstall": "node -e \"const ua=(process.env.npm_config_user_agent||'').toLowerCase(); if(!ua.includes('pnpm')) { console.error('This project uses pnpm only. Run: pnpm install'); process.exit(1); }\"",
    "prepare:song-data": "node ./scripts/prepare-song-data.mjs",
    "prepare:song-data:local": "set \"SONG_DATA_SOURCE=local\" && node ./scripts/prepare-song-data.mjs",
    "update:preview": "eas update --channel preview",
    "update:production": "eas update --channel production",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "expo": "~54.0.12",
    "expo-asset": "~12.0.9",
    "expo-constants": "~18.0.10",
    "expo-file-system": "~19.0.17",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-network": "~8.0.7",
    "expo-router": "~6.0.10",
    "expo-sharing": "~14.0.7",
    "expo-status-bar": "~3.0.8",
    "firebase": "^12.4.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.6",
    "typescript": "~5.9.2"
  }
}
