{
  "expo": {
    "name": "Slovenske Ludovky Mobile",
    "slug": "slovenskeludovky",
    "scheme": "slovenskeludovkymobile",
    "owner": "tochosk",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/ludovkylogo.png",
    "updates": {
      "url": "https://u.expo.dev/efdeac7f-c2b8-4973-998d-52c54f2d6dbf",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.tochosk.slovenskeludovky",
      "icon": "./assets/ludovkylogo.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ludovkylogo.png",
        "backgroundColor": "#eef7fd"
      },
      "package": "com.tochosk.slovenskeludovky",
      "versionCode": 2
    },
    "splash": {
      "image": "./assets/ludovkylogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#eef7fd"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "efdeac7f-c2b8-4973-998d-52c54f2d6dbf"
      }
    }
  }
}
